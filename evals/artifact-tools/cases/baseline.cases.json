  {
    "id": "xlsx_edit_export_roundtrip",
    "artifactKind": "workbook",
    "format": "xlsx",
    "input": "evals/artifact-tools/fixtures/xlsx/formula-style-model.xlsx",
    "goal": "Apply declaration-style XLSX edits, export, reopen, and verify the changed values, formulas, and styles.",
    "requiredCapabilities": ["load", "inspect", "edit", "validate", "export", "roundtrip"],
    "expectedEvidence": ["operation log", "dirty range", "exported workbook", "reopened cell values", "reopened formulas", "reopened styles"],
    "expected": {
      "allowedDiagnosticCodes": ["xlsx_formula_error"],
      "xlsx": {
        "sheetNames": ["Data", "Summary"],
        "minimumFormulaCount": 5,
        "formulaErrorCount": 1
      },
      "editRoundtrip": {
        "operations": [
          {
            "op": "range.setValues",
            "target": "Summary!A6:B6",
            "values": [["Edited status", "OK"]]
          },
          {
            "op": "range.setStyles",
            "target": "Summary!B6",
            "style": {
              "fill": "#10B981",
              "font": { "bold": true, "color": "#FFFFFF" },
              "alignment": { "horizontal": "center" }
            }
          },
          {
            "op": "range.setFormulas",
            "target": "Summary!B7",
            "formulas": [[{ "formula": "SUM(Data!D2:D4)+9", "result": 100 }]]
          }
        ],
        "verifyTarget": "Summary!A6:B7",
        "after": {
          "allowedDiagnosticCodes": ["xlsx_formula_error"],
          "target": "Summary!A6:B7",
          "xlsx": {
            "formulaErrorCount": 1,
            "cells": [
              { "ref": "Summary!B6", "value": "OK", "fillRgb": "10B981" },
              { "ref": "Summary!B7", "formula": "SUM(Data!D2:D4)+9" }
            ]
          }
        }
      }
    },
    "checks": ["declarative edit", "export", "roundtrip reopen", "style equality", "formula equality"]
  },
  {
    "id": "xlsx_render_trace_recalculate",
    "artifactKind": "workbook",
    "format": "xlsx",
    "input": "evals/artifact-tools/fixtures/xlsx/formula-style-model.xlsx",
    "goal": "Render a real XLSX range to PNG, trace formula dependencies, change an input, recalculate a dependent formula, export, and reopen.",
    "requiredCapabilities": ["load", "inspect", "render", "trace", "recalculate", "export", "roundtrip"],
    "expectedEvidence": ["png render", "formula graph", "dependency refs", "updated cached formula result", "reopened workbook"],
    "expected": {
      "allowedDiagnosticCodes": ["xlsx_formula_error"],
      "render": {
        "target": "Summary!A1:D7",
        "scale": 2
      },
      "xlsx": {
        "sheetNames": ["Data", "Summary"],
        "minimumFormulaCount": 5,
        "formulaErrorCount": 1
      },
      "formulaTrace": {
        "target": "Summary!B3",
        "maxDepth": 5,
        "mustReference": ["Data!D2:D4", "Data!D2", "Data!B2"]
      },
      "recalculate": {
        "beforeOperations": [
          {
            "op": "range.setValues",
            "target": "Data!B2",
            "values": [[10]]
          }
        ],
        "target": "Summary!B3",
        "after": {
          "allowedDiagnosticCodes": ["xlsx_formula_error"],
          "target": "Summary!B3",
          "xlsx": {
            "formulaErrorCount": 1,
            "cells": [
              { "ref": "Summary!B3", "value": 187, "formula": "SUM(Data!D2:D4)", "fillRgb": "DCFCE7" }
            ]
          }
        }
      }
    },
    "checks": ["png render", "formula trace", "local recalculate", "export reopen"]
  },
  {
    "id": "xlsx_search_index_observation",
    "artifactKind": "workbook",
    "format": "xlsx",
    "input": "evals/artifact-tools/fixtures/xlsx/formula-style-model.xlsx",
    "goal": "Build an XLSX index and search compact candidate evidence across text, styles, formulas, errors, tables, merges, comments, defined names, hidden structure, package inventory, and table queries.",
    "requiredCapabilities": ["load", "index", "search", "query", "inspect"],
    "expectedEvidence": ["candidate cells", "style matches", "formula matches", "error matches", "table inventory", "merge inventory", "comment inventory", "defined names", "hidden rows", "image anchors", "query aggregates"],
    "expected": {
      "allowedDiagnosticCodes": ["xlsx_formula_error"],
      "xlsx": {
        "sheetNames": ["Data", "Summary"],
        "requiredTables": ["SalesTable"],
        "requiredMerges": ["Summary!A1:D1"],
        "minimumFormulaCount": 5,
        "formulaErrorCount": 1
      },
      "searches": [
        { "searchKind": "text", "query": "Alpha", "mustReference": ["Data!A2"] },
        { "searchKind": "style", "fillRgb": "DCFCE7", "mustReference": ["Summary!B3"] },
        { "searchKind": "formula", "query": "Data!D2:D4", "mustReference": ["Summary!B3"] },
        { "searchKind": "error", "error": "#REF", "mustReference": ["Summary!B4"] },
        { "searchKind": "table", "query": "SalesTable", "minimumMatches": 1 },
        { "searchKind": "merge", "query": "Summary!A1:D1", "mustReference": ["Summary!A1:D1"] },
        { "searchKind": "comment", "query": "artifact_search", "mustReference": ["Data!A2"] },
        { "searchKind": "definedName", "query": "TotalRevenue", "minimumMatches": 1 },
        { "searchKind": "hidden", "query": "Beta", "mustReference": ["Data!A3"] },
        { "searchKind": "image", "minimumMatches": 1 },
        { "searchKind": "imageAnchor", "query": "Summary", "minimumMatches": 1 }
      ],
      "queries": [
        {
          "table": "SalesTable",
          "aggregate": { "op": "max", "column": "Revenue" },
          "sortBy": "Revenue",
          "top": 1,
          "aggregateValue": 45,
          "mustReference": ["Data!A3:D3"]
        },
        {
          "table": "SalesTable",
          "groupBy": "Item",
          "aggregate": { "op": "sum", "column": "Revenue" },
          "topGroups": 3,
          "mustGroups": [{ "key": "Beta", "value": 45 }]
        }
      ]
    },
    "checks": ["xlsx index cache", "artifact search", "artifact query", "compact observation"]
  },
