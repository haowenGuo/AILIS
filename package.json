{
  "name": "ailis",
  "version": "1.0.6",
  "description": "AILIS desktop embodied-agent companion with VRM avatar, realtime voice, memory, and native AILIS agent runtime.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --configLoader native --host 0.0.0.0 --port 5173",
    "build": "vite build --configLoader native --base ./ && node scripts/copy-static-assets.mjs",
    "llm:vllm:serve": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-vllm-local.ps1",
    "llm:vllm:serve:hf": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-vllm-local.ps1 -Source hf -Model Qwen/Qwen2.5-7B-Instruct",
    "llm:vllm:serve:modelscope": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-vllm-local.ps1 -Source modelscope -Model Qwen/Qwen2.5-7B-Instruct",
    "llm:vllm:oneclick": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bootstrap-vllm-local.ps1 -Source hf -Model Qwen/Qwen2.5-7B-Instruct -Start -Detached -WaitReady",
    "llm:vllm:oneclick:hf": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bootstrap-vllm-local.ps1 -Source hf -Model Qwen/Qwen2.5-7B-Instruct -Start -Detached -WaitReady",
    "llm:vllm:oneclick:modelscope": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bootstrap-vllm-local.ps1 -Source modelscope -Model Qwen/Qwen2.5-7B-Instruct -Start -Detached -WaitReady",
    "llm:vllm:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bootstrap-vllm-local.ps1 -DryRun",
    "ailis:web-runtime:prepare": "node scripts/prepare-ailis-web-runtime.mjs",
    "ailis:asr-runtime:prepare": "node scripts/prepare-ailis-asr-runtime.mjs",
    "ailis:voice-runtime:prepare": "node scripts/prepare-ailis-voice-runtime.mjs",
    "ailis:runtime-packs:manifest": "node scripts/build-ailis-runtime-packs.mjs --manifest-only",
    "ailis:runtime-packs:build": "node scripts/build-ailis-runtime-packs.mjs",
    "openclaw:prepare-runtime": "node scripts/prepare-openclaw-runtime.mjs",
    "openclaw:validate-tools": "node scripts/validate-openclaw-tool-surface.mjs",
    "openclaw:smoke-tools": "node scripts/smoke-openclaw-tools.mjs",
    "openclaw:validate": "pnpm openclaw:validate-tools && pnpm test:openclaw-tools && pnpm openclaw:smoke-tools",
    "ailis:smoke-gateway": "node scripts/smoke-ailis-gateway.mjs",
    "ailis:smoke-agent": "node scripts/smoke-ailis-agent.mjs",
    "ailis:smoke-email": "node scripts/smoke-ailis-email.mjs",
    "ailis:smoke-file-manager": "node scripts/smoke-ailis-file-manager.mjs",
    "ailis:smoke-computer": "node scripts/smoke-ailis-computer.mjs",
    "ailis:smoke-code": "node scripts/smoke-ailis-code.mjs",
    "ailis:benchmark-execution": "node scripts/benchmark-ailis-execution.mjs",
    "ailis:validate-harness": "node scripts/validate-ailis-harness.mjs",
    "ailis:tool-doctor": "node scripts/run-ailis-tool-doctor.mjs --mode smoke --run-eval",
    "ailis:tool-doctor:plan": "node scripts/run-ailis-tool-doctor.mjs --mode smoke",
    "ailis:setup-standard-tool-packs": "node scripts/setup-ailis-standard-tool-packs.mjs --write",
    "ailis:setup-standard-tool-packs:verify": "node scripts/setup-ailis-standard-tool-packs.mjs --write --enable-auth-adapters --enable-local-adapters --verify-adapters",
    "ailis:self-debug-eval": "node scripts/run-ailis-self-debug-eval.mjs",
    "ailis:validate-tools-deep": "node scripts/validate-ailis-tool-layer.mjs",
    "ailis:verify-runtime-alignment": "node scripts/verify-ailis-runtime-alignment.mjs",
    "ailis:mcp-soak": "node scripts/soak-ailis-mcp.mjs",
    "bench:swebench-lite:prepare": "node scripts/prepare-swebench-lite-sample.mjs",
    "bench:swebench-lite:prepare-wheelhouse": "node scripts/prepare-swebench-wheelhouse.mjs",
    "bench:swebench-lite:smoke": "node scripts/run-swebench-lite-harness-smoke.mjs",
    "bench:swebench-lite:execute": "node scripts/run-swebench-lite-execution.mjs",
    "bench:swebench-lite:selftest": "node scripts/run-swebench-execution-selftest.mjs",
    "bench:osworld:readiness": "node scripts/run-osworld-pc-readiness.mjs",
    "bench:gaia:official:l1": "node scripts/run-gaia-official.mjs --split validation --levels 1 --max-agent-steps 20 --request-timeout-ms 300000 --llm-timeout-ms 120000 --task-retries 1",
    "bench:gaia:official:l1-l2": "node scripts/run-gaia-official.mjs --split validation --levels 1,2 --max-agent-steps 25 --request-timeout-ms 360000 --llm-timeout-ms 120000 --task-retries 1",
    "bench:gaia:official:download:l1": "node scripts/run-gaia-official.mjs --split validation --levels 1 --download-only",
    "bench:agentbench:ailis:list": "node scripts/run-agentbench-ailis.mjs --list",
    "bench:agentbench:ailis:smoke": "node scripts/run-agentbench-ailis.mjs --task data-analysis-cross-reference --keep-workspace --max-agent-steps 20",
    "bench:agentbench:ailis:memory": "node scripts/run-agentbench-ailis.mjs --suite memory --keep-workspace --max-agent-steps 25",
    "bench:osworld:quickstart:wsl": "node scripts/run-wsl-repo-script.mjs scripts/run-osworld-wsl-quickstart.sh",
    "bench:osworld:ailis:test-small:wsl": "node scripts/run-wsl-repo-script.mjs scripts/run-osworld-ailis-test-small-wsl.sh",
    "eval:ailis-humanlike": "node scripts/run-ailis-humanlike-eval.mjs",
    "eval:ailis-humanlike:validate": "node scripts/run-ailis-humanlike-eval.mjs --validate-only",
    "eval:ailis-humanlike:generate": "node scripts/generate-ailis-humanlike-scenarios.mjs",
    "eval:ailis-humanlike:report": "node scripts/analyze-ailis-humanlike-scenarios.mjs",
    "eval:ailis-humanlike:real": "node scripts/run-ailis-humanlike-real-eval.mjs",
    "eval:ailis-humanlike:long-term:validate": "node scripts/run-ailis-humanlike-eval.mjs --scenarios evals/ailis-humanlike/long-term-companionship.scenarios.jsonl --validate-only",
    "eval:ailis-humanlike:long-term:real": "node scripts/run-ailis-humanlike-real-eval.mjs --scenarios evals/ailis-humanlike/long-term-companionship.scenarios.jsonl --output-dir eval-results/ailis-humanlike-long-term-real",
    "eval:ailis-humanlike:longitudinal:generate": "node scripts/generate-ailis-longitudinal-companionship-scenarios.mjs",
    "eval:ailis-humanlike:longitudinal:validate": "node scripts/run-ailis-humanlike-eval.mjs --scenarios evals/ailis-humanlike/longitudinal-companionship-30d.scenarios.jsonl --validate-only",
    "eval:ailis-humanlike:longitudinal:real": "node scripts/run-ailis-humanlike-real-eval.mjs --scenarios evals/ailis-humanlike/longitudinal-companionship-30d.scenarios.jsonl --output-dir eval-results/ailis-humanlike-longitudinal-30d-real --concurrency 1 --progress-every 1",
    "eval:ailis-humanlike:longitudinal-agent": "node scripts/run-ailis-longitudinal-agent-eval.mjs",
    "eval:ailis-humanlike:longitudinal-agent:validate": "node scripts/run-ailis-longitudinal-agent-eval.mjs --validate-only",
    "eval:ailis-humanlike:longitudinal-agent:smoke": "node scripts/run-ailis-longitudinal-agent-eval.mjs --limit 12 --progress-every 1",
    "ailis:validate-gateway": "pnpm ailis:verify-runtime-alignment && pnpm ailis:validate-harness && pnpm test:ailis-runtime && pnpm test:ailis-tool-contracts && pnpm test:ailis-contract-compiler && pnpm test:ailis-tool-doctor && pnpm test:ailis-capability-manager && pnpm test:ailis-tool-acquisition && pnpm test:ailis-self-debugger && pnpm test:ailis-platform-adapter && pnpm test:ailis-desktop-platform-adapter && pnpm test:ailis-skills && pnpm test:ailis-memory && pnpm test:ailis-gateway && pnpm test:ailis-agent && pnpm test:ailis-agent-execution-flow && pnpm test:ailis-llm-planner && pnpm test:ailis-email && pnpm test:ailis-file-manager && pnpm test:ailis-computer && pnpm test:ailis-computer-advanced && pnpm test:ailis-code && pnpm bench:osworld:readiness && pnpm ailis:smoke-gateway && pnpm ailis:smoke-agent && pnpm ailis:smoke-email && pnpm ailis:smoke-file-manager && pnpm ailis:smoke-computer && pnpm ailis:smoke-code",
    "preview": "vite preview --configLoader native --host 0.0.0.0 --port 4173",
    "desktop:dev": "concurrently -k -s first -n vite,electron -c cyan,magenta \"pnpm dev\" \"wait-on http://127.0.0.1:5173 && cross-env AILIS_DESKTOP_DEV_URL=http://127.0.0.1:5173 electron .\"",
    "desktop:start": "pnpm build && electron .",
    "desktop:package": "pnpm desktop:package:win",
    "desktop:package:win": "pnpm desktop:package:win:lite",
    "desktop:package:win:lite": "pnpm build && pnpm exec electron-builder --config electron-builder.yml --win nsis portable",
    "desktop:package:win:voice": "pnpm desktop:package:win:offline-voice",
    "desktop:package:win:offline-voice": "pnpm ailis:voice-runtime:prepare && pnpm build && pnpm exec electron-builder --config electron-builder.voice.yml --win --dir",
    "desktop:package:linux": "pnpm build && pnpm exec electron-builder --config electron-builder.yml --linux AppImage deb tar.gz",
    "desktop:package:all": "pnpm build && pnpm exec electron-builder --config electron-builder.yml --win nsis portable --linux AppImage deb tar.gz",
    "android:doctor": "node scripts/check-android-readiness.mjs",
    "test:openclaw-tools": "node --test tests/openclaw-tool-surface.test.mjs",
    "test:desktop-llm": "node --test tests/desktop-llm-provider.test.mjs",
    "test:ailis-persona-renderer": "node --test tests/ailis-persona-renderer.test.mjs",
    "test:ailis-character-runtime": "node --test tests/ailis-character-runtime.test.mjs",
    "motion:intake:scan": "node scripts/scan-motion-intake.mjs",
    "motion:intake:verify": "node scripts/scan-motion-intake.mjs --verify",
    "test:ailis-humanlike-eval": "node --test tests/ailis-humanlike-eval.test.mjs",
    "test:ailis-gateway": "node --test tests/ailis-gateway.test.mjs",
    "test:ailis-runtime": "node --test tests/ailis-runtime.test.mjs",
    "test:ailis-agent-execution-flow": "node --test tests/ailis-agent-execution-flow.test.mjs",
    "test:ailis-tool-contracts": "node --test tests/ailis-tool-contracts.test.mjs",
    "test:ailis-contract-compiler": "node --test tests/ailis-contract-compiler.test.mjs",
    "test:ailis-tool-doctor": "node --test tests/ailis-tool-doctor.test.mjs",
    "test:ailis-capability-manager": "node --test tests/ailis-capability-manager.test.mjs",
    "test:ailis-tool-acquisition": "node --test tests/ailis-tool-acquisition-gateway.test.mjs",
    "test:ailis-standard-tool-packs": "node --test tests/ailis-standard-tool-packs.test.mjs",
    "test:ailis-self-debugger": "node --test tests/ailis-self-debugger.test.mjs",
    "test:ailis-platform-adapter": "node --test tests/ailis-platform-adapter.test.mjs",
    "test:ailis-desktop-platform-adapter": "node --test tests/ailis-desktop-platform-adapter.test.mjs",
    "test:swebench-setup-recipes": "node --test tests/swebench-setup-recipes.test.mjs",
    "test:ailis-skills": "node --test tests/ailis-skills.test.mjs",
    "test:ailis-memory": "node --test tests/ailis-memory-store.test.mjs",
    "test:ailis-agent": "node --test tests/ailis-agent-runner.test.mjs",
    "test:ailis-llm-planner": "node --test tests/ailis-llm-planner.test.mjs",
    "test:ailis-email": "node --test tests/ailis-email-tool.test.mjs",
    "test:ailis-file-manager": "node --test tests/ailis-file-manager-tool.test.mjs",
    "test:ailis-computer": "node --test tests/ailis-computer-tool.test.mjs",
    "test:ailis-computer-advanced": "node --test tests/ailis-computer-advanced-tool.test.mjs",
    "test:ailis-code": "node --test tests/ailis-code-tool.test.mjs"
  },
  "keywords": [],
