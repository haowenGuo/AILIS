{
  "name": "humanclaw",
  "version": "1.0.3",
  "description": "HumanClaw desktop pet with VRM avatar, companion chat, and optional OpenClaw runtime integration.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --configLoader native --host 0.0.0.0 --port 5173",
    "build": "vite build --configLoader native --base ./ && node scripts/copy-static-assets.mjs",
    "openclaw:prepare-runtime": "node scripts/prepare-openclaw-runtime.mjs",
    "openclaw:validate-tools": "node scripts/validate-openclaw-tool-surface.mjs",
    "openclaw:smoke-tools": "node scripts/smoke-openclaw-tools.mjs",
    "openclaw:validate": "pnpm openclaw:validate-tools && pnpm test:openclaw-tools && pnpm openclaw:smoke-tools",
    "humanclaw:smoke-gateway": "node scripts/smoke-humanclaw-gateway.mjs",
    "humanclaw:smoke-agent": "node scripts/smoke-humanclaw-agent.mjs",
    "humanclaw:smoke-email": "node scripts/smoke-humanclaw-email.mjs",
    "humanclaw:smoke-file-manager": "node scripts/smoke-humanclaw-file-manager.mjs",
    "humanclaw:smoke-computer": "node scripts/smoke-humanclaw-computer.mjs",
    "humanclaw:smoke-code": "node scripts/smoke-humanclaw-code.mjs",
    "humanclaw:benchmark-execution": "node scripts/benchmark-humanclaw-execution.mjs",
    "humanclaw:validate-harness": "node scripts/validate-humanclaw-harness.mjs",
    "humanclaw:tool-doctor": "node scripts/run-humanclaw-tool-doctor.mjs --mode smoke --run-eval",
    "humanclaw:tool-doctor:plan": "node scripts/run-humanclaw-tool-doctor.mjs --mode smoke",
    "humanclaw:self-debug-eval": "node scripts/run-humanclaw-self-debug-eval.mjs",
    "humanclaw:validate-tools-deep": "node scripts/validate-humanclaw-tool-layer.mjs",
    "humanclaw:verify-runtime-alignment": "node scripts/verify-humanclaw-runtime-alignment.mjs",
    "humanclaw:mcp-soak": "node scripts/soak-humanclaw-mcp.mjs",
    "bench:swebench-lite:prepare": "node scripts/prepare-swebench-lite-sample.mjs",
    "bench:swebench-lite:prepare-wheelhouse": "node scripts/prepare-swebench-wheelhouse.mjs",
    "bench:swebench-lite:smoke": "node scripts/run-swebench-lite-harness-smoke.mjs",
    "bench:swebench-lite:execute": "node scripts/run-swebench-lite-execution.mjs",
    "bench:swebench-lite:selftest": "node scripts/run-swebench-execution-selftest.mjs",
    "bench:osworld:readiness": "node scripts/run-osworld-pc-readiness.mjs",
    "bench:gaia:official:l1": "node scripts/run-gaia-official.mjs --split validation --levels 1 --max-agent-steps 20 --request-timeout-ms 300000 --llm-timeout-ms 120000 --task-retries 1",
    "bench:gaia:official:l1-l2": "node scripts/run-gaia-official.mjs --split validation --levels 1,2 --max-agent-steps 25 --request-timeout-ms 360000 --llm-timeout-ms 120000 --task-retries 1",
    "bench:gaia:official:download:l1": "node scripts/run-gaia-official.mjs --split validation --levels 1 --download-only",
    "bench:agentbench:aigl:list": "node scripts/run-agentbench-aigl.mjs --list",
    "bench:agentbench:aigl:smoke": "node scripts/run-agentbench-aigl.mjs --task data-analysis-cross-reference --keep-workspace --max-agent-steps 20",
    "bench:agentbench:aigl:memory": "node scripts/run-agentbench-aigl.mjs --suite memory --keep-workspace --max-agent-steps 25",
    "bench:osworld:quickstart:wsl": "wsl -d Ubuntu-22.04 -- bash /mnt/f/AIGril/scripts/run-osworld-wsl-quickstart.sh",
    "bench:osworld:aigl:test-small:wsl": "wsl -d Ubuntu-22.04 -- bash /mnt/f/AIGril/scripts/run-osworld-aigl-test-small-wsl.sh",
    "eval:aigl-humanlike": "node scripts/run-aigl-humanlike-eval.mjs",
    "eval:aigl-humanlike:validate": "node scripts/run-aigl-humanlike-eval.mjs --validate-only",
    "eval:aigl-humanlike:generate": "node scripts/generate-aigl-humanlike-scenarios.mjs",
    "eval:aigl-humanlike:report": "node scripts/analyze-aigl-humanlike-scenarios.mjs",
    "eval:aigl-humanlike:real": "node scripts/run-aigl-humanlike-real-eval.mjs",
    "eval:aigl-humanlike:long-term:validate": "node scripts/run-aigl-humanlike-eval.mjs --scenarios evals/aigl-humanlike/long-term-companionship.scenarios.jsonl --validate-only",
    "eval:aigl-humanlike:long-term:real": "node scripts/run-aigl-humanlike-real-eval.mjs --scenarios evals/aigl-humanlike/long-term-companionship.scenarios.jsonl --output-dir eval-results/aigl-humanlike-long-term-real",
    "eval:aigl-humanlike:longitudinal:generate": "node scripts/generate-aigl-longitudinal-companionship-scenarios.mjs",
    "eval:aigl-humanlike:longitudinal:validate": "node scripts/run-aigl-humanlike-eval.mjs --scenarios evals/aigl-humanlike/longitudinal-companionship-30d.scenarios.jsonl --validate-only",
    "eval:aigl-humanlike:longitudinal:real": "node scripts/run-aigl-humanlike-real-eval.mjs --scenarios evals/aigl-humanlike/longitudinal-companionship-30d.scenarios.jsonl --output-dir eval-results/aigl-humanlike-longitudinal-30d-real --concurrency 1 --progress-every 1",
    "eval:aigl-humanlike:longitudinal-agent": "node scripts/run-aigl-longitudinal-agent-eval.mjs",
    "eval:aigl-humanlike:longitudinal-agent:validate": "node scripts/run-aigl-longitudinal-agent-eval.mjs --validate-only",
    "eval:aigl-humanlike:longitudinal-agent:smoke": "node scripts/run-aigl-longitudinal-agent-eval.mjs --limit 12 --progress-every 1",
    "humanclaw:validate-gateway": "pnpm humanclaw:verify-runtime-alignment && pnpm humanclaw:validate-harness && pnpm test:humanclaw-runtime && pnpm test:humanclaw-tool-contracts && pnpm test:humanclaw-contract-compiler && pnpm test:humanclaw-tool-doctor && pnpm test:humanclaw-capability-manager && pnpm test:humanclaw-tool-acquisition && pnpm test:humanclaw-self-debugger && pnpm test:humanclaw-platform-adapter && pnpm test:humanclaw-desktop-platform-adapter && pnpm test:humanclaw-skills && pnpm test:humanclaw-memory && pnpm test:humanclaw-gateway && pnpm test:humanclaw-agent && pnpm test:humanclaw-agent-execution-flow && pnpm test:humanclaw-llm-planner && pnpm test:humanclaw-email && pnpm test:humanclaw-file-manager && pnpm test:humanclaw-computer && pnpm test:humanclaw-computer-advanced && pnpm test:humanclaw-code && pnpm bench:osworld:readiness && pnpm humanclaw:smoke-gateway && pnpm humanclaw:smoke-agent && pnpm humanclaw:smoke-email && pnpm humanclaw:smoke-file-manager && pnpm humanclaw:smoke-computer && pnpm humanclaw:smoke-code",
    "preview": "vite preview --configLoader native --host 0.0.0.0 --port 4173",
    "desktop:dev": "concurrently -k -s first -n vite,electron -c cyan,magenta \"pnpm dev\" \"wait-on http://127.0.0.1:5173 && cross-env AIGRIL_DESKTOP_DEV_URL=http://127.0.0.1:5173 electron .\"",
    "desktop:start": "pnpm build && electron .",
    "desktop:package": "pnpm desktop:package:win",
    "desktop:package:win": "pnpm openclaw:prepare-runtime && pnpm build && pnpm exec electron-builder --config electron-builder.yml --win nsis portable",
    "desktop:package:linux": "pnpm openclaw:prepare-runtime && pnpm build && pnpm exec electron-builder --config electron-builder.yml --linux AppImage deb tar.gz",
    "desktop:package:all": "pnpm openclaw:prepare-runtime && pnpm build && pnpm exec electron-builder --config electron-builder.yml --win nsis portable --linux AppImage deb tar.gz",
    "android:doctor": "node scripts/check-android-readiness.mjs",
    "test:openclaw-tools": "node --test tests/openclaw-tool-surface.test.mjs",
    "test:desktop-llm": "node --test tests/desktop-llm-provider.test.mjs",
    "test:aigl-persona-renderer": "node --test tests/aigl-persona-renderer.test.mjs",
    "test:aigl-character-runtime": "node --test tests/aigl-character-runtime.test.mjs",
    "motion:intake:scan": "node scripts/scan-motion-intake.mjs",
    "motion:intake:verify": "node scripts/scan-motion-intake.mjs --verify",
    "test:aigl-humanlike-eval": "node --test tests/aigl-humanlike-eval.test.mjs",
    "test:humanclaw-gateway": "node --test tests/humanclaw-gateway.test.mjs",
    "test:humanclaw-runtime": "node --test tests/humanclaw-runtime.test.mjs",
    "test:humanclaw-agent-execution-flow": "node --test tests/humanclaw-agent-execution-flow.test.mjs",
    "test:humanclaw-tool-contracts": "node --test tests/humanclaw-tool-contracts.test.mjs",
    "test:humanclaw-contract-compiler": "node --test tests/humanclaw-contract-compiler.test.mjs",
    "test:humanclaw-tool-doctor": "node --test tests/humanclaw-tool-doctor.test.mjs",
    "test:humanclaw-capability-manager": "node --test tests/humanclaw-capability-manager.test.mjs",
    "test:humanclaw-tool-acquisition": "node --test tests/humanclaw-tool-acquisition-gateway.test.mjs",
    "test:humanclaw-self-debugger": "node --test tests/humanclaw-self-debugger.test.mjs",
    "test:humanclaw-platform-adapter": "node --test tests/humanclaw-platform-adapter.test.mjs",
    "test:humanclaw-desktop-platform-adapter": "node --test tests/humanclaw-desktop-platform-adapter.test.mjs",
    "test:swebench-setup-recipes": "node --test tests/swebench-setup-recipes.test.mjs",
    "test:humanclaw-skills": "node --test tests/humanclaw-skills.test.mjs",
    "test:humanclaw-memory": "node --test tests/humanclaw-memory-store.test.mjs",
    "test:humanclaw-agent": "node --test tests/humanclaw-agent-runner.test.mjs",
    "test:humanclaw-llm-planner": "node --test tests/humanclaw-llm-planner.test.mjs",
    "test:humanclaw-email": "node --test tests/humanclaw-email-tool.test.mjs",
    "test:humanclaw-file-manager": "node --test tests/humanclaw-file-manager-tool.test.mjs",
    "test:humanclaw-computer": "node --test tests/humanclaw-computer-tool.test.mjs",
    "test:humanclaw-computer-advanced": "node --test tests/humanclaw-computer-advanced-tool.test.mjs",
    "test:humanclaw-code": "node --test tests/humanclaw-code-tool.test.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@pixiv/three-vrm": "^3.5.1",
    "@pixiv/three-vrm-animation": "^3.5.1",
    "@xenova/transformers": "^2.17.2",
    "imapflow": "^1.3.3",
    "mailparser": "^3.9.8",
    "node-pty": "^1.1.0",
    "nodemailer": "^8.0.7",
    "pinyin-pro": "^3.28.1",
    "three": "^0.183.2",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-filesystem": "2026.1.14",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  }
}
