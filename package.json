{
  "name": "humanclaw",
  "version": "1.0.1",
  "description": "HumanClaw desktop pet with VRM avatar, companion chat, and optional OpenClaw runtime integration.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --configLoader native --host 0.0.0.0 --port 5173",
    "build": "vite build --configLoader native --base ./ && node scripts/copy-static-assets.mjs",
    "openclaw:prepare-runtime": "node scripts/prepare-openclaw-runtime.mjs",
    "openclaw:validate-tools": "node scripts/validate-openclaw-tool-surface.mjs",
    "openclaw:smoke-tools": "node scripts/smoke-openclaw-tools.mjs",
    "openclaw:validate": "pnpm openclaw:validate-tools && pnpm test:openclaw-tools && pnpm openclaw:smoke-tools",
    "humanclaw:smoke-gateway": "node scripts/smoke-humanclaw-gateway.mjs",
    "humanclaw:smoke-agent": "node scripts/smoke-humanclaw-agent.mjs",
    "humanclaw:smoke-email": "node scripts/smoke-humanclaw-email.mjs",
    "humanclaw:smoke-file-manager": "node scripts/smoke-humanclaw-file-manager.mjs",
    "humanclaw:smoke-computer": "node scripts/smoke-humanclaw-computer.mjs",
    "humanclaw:smoke-code": "node scripts/smoke-humanclaw-code.mjs",
    "humanclaw:benchmark-execution": "node scripts/benchmark-humanclaw-execution.mjs",
    "humanclaw:validate-harness": "node scripts/validate-humanclaw-harness.mjs",
    "humanclaw:validate-tools-deep": "node scripts/validate-humanclaw-tool-layer.mjs",
    "humanclaw:verify-runtime-alignment": "node scripts/verify-humanclaw-runtime-alignment.mjs",
    "eval:aigl-humanlike": "node scripts/run-aigl-humanlike-eval.mjs",
    "eval:aigl-humanlike:validate": "node scripts/run-aigl-humanlike-eval.mjs --validate-only",
    "eval:aigl-humanlike:generate": "node scripts/generate-aigl-humanlike-scenarios.mjs",
    "eval:aigl-humanlike:report": "node scripts/analyze-aigl-humanlike-scenarios.mjs",
    "eval:aigl-humanlike:real": "node scripts/run-aigl-humanlike-real-eval.mjs",
    "eval:aigl-humanlike:long-term:validate": "node scripts/run-aigl-humanlike-eval.mjs --scenarios evals/aigl-humanlike/long-term-companionship.scenarios.jsonl --validate-only",
    "eval:aigl-humanlike:long-term:real": "node scripts/run-aigl-humanlike-real-eval.mjs --scenarios evals/aigl-humanlike/long-term-companionship.scenarios.jsonl --output-dir eval-results/aigl-humanlike-long-term-real",
    "humanclaw:validate-gateway": "pnpm humanclaw:verify-runtime-alignment && pnpm humanclaw:validate-harness && pnpm test:humanclaw-runtime && pnpm test:humanclaw-tool-contracts && pnpm test:humanclaw-skills && pnpm test:humanclaw-memory && pnpm test:humanclaw-gateway && pnpm test:humanclaw-agent && pnpm test:humanclaw-llm-planner && pnpm test:humanclaw-email && pnpm test:humanclaw-file-manager && pnpm test:humanclaw-computer && pnpm test:humanclaw-computer-advanced && pnpm test:humanclaw-code && pnpm humanclaw:smoke-gateway && pnpm humanclaw:smoke-agent && pnpm humanclaw:smoke-email && pnpm humanclaw:smoke-file-manager && pnpm humanclaw:smoke-computer && pnpm humanclaw:smoke-code",
    "preview": "vite preview --configLoader native --host 0.0.0.0 --port 4173",
    "desktop:dev": "concurrently -k -s first -n vite,electron -c cyan,magenta \"pnpm dev\" \"wait-on http://127.0.0.1:5173 && cross-env AIGRIL_DESKTOP_DEV_URL=http://127.0.0.1:5173 electron .\"",
    "desktop:start": "pnpm build && electron .",
    "desktop:package": "pnpm openclaw:prepare-runtime && pnpm build && pnpm exec electron-builder --config electron-builder.yml --win nsis portable",
    "test:openclaw-tools": "node --test tests/openclaw-tool-surface.test.mjs",
    "test:desktop-llm": "node --test tests/desktop-llm-provider.test.mjs",
    "test:aigl-humanlike-eval": "node --test tests/aigl-humanlike-eval.test.mjs",
    "test:humanclaw-gateway": "node --test tests/humanclaw-gateway.test.mjs",
    "test:humanclaw-runtime": "node --test tests/humanclaw-runtime.test.mjs",
    "test:humanclaw-tool-contracts": "node --test tests/humanclaw-tool-contracts.test.mjs",
    "test:humanclaw-skills": "node --test tests/humanclaw-skills.test.mjs",
    "test:humanclaw-memory": "node --test tests/humanclaw-memory-store.test.mjs",
    "test:humanclaw-agent": "node --test tests/humanclaw-agent-runner.test.mjs",
    "test:humanclaw-llm-planner": "node --test tests/humanclaw-llm-planner.test.mjs",
    "test:humanclaw-email": "node --test tests/humanclaw-email-tool.test.mjs",
    "test:humanclaw-file-manager": "node --test tests/humanclaw-file-manager-tool.test.mjs",
    "test:humanclaw-computer": "node --test tests/humanclaw-computer-tool.test.mjs",
    "test:humanclaw-computer-advanced": "node --test tests/humanclaw-computer-advanced-tool.test.mjs",
    "test:humanclaw-code": "node --test tests/humanclaw-code-tool.test.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@pixiv/three-vrm": "^3.5.1",
    "@pixiv/three-vrm-animation": "^3.5.1",
    "@xenova/transformers": "^2.17.2",
    "imapflow": "^1.3.3",
    "mailparser": "^3.9.8",
    "node-pty": "^1.1.0",
    "nodemailer": "^8.0.7",
    "pinyin-pro": "^3.28.1",
    "three": "^0.183.2",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  }
}
